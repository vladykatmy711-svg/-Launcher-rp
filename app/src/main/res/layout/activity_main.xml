<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_bg"
    android:padding="20dp">

    <!-- Верхняя строка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pompeii RP"
            android:textColor="#F500BD"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Уровень 16"
            android:textColor="#00A1D5"
            android:textSize="16sp"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_pcoin"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1240"
                android:textColor="#008E67"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Центральные три иконки (главные) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Кейс -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_case"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КЕЙС"
                android:textColor="#008E67"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- Профиль (шлем) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_helmet_profile"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПРОФИЛЬ"
                android:textColor="#F500BD"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- Настройки -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_settings"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="НАСТРОЙКИ"
                android:textColor="#F500BD"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Нижняя панель с тремя маленькими иконками -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="30dp"
        android:paddingBottom="10dp">

        <!-- Служба поддержки -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="start"
            android:paddingStart="10dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_lamborghini_key"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СЛУЖБА ПОДДЕРЖКИ"
                android:textColor="#00A1D5"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                android:layout_gravity="center_vertical"/>

        </LinearLayout>

        <!-- Магазин -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shop"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МАГАЗИН"
                android:textColor="#008E67"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- События -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_event"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СОБЫТИЯ"
                android:textColor="#F500BD"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Надпись RECOMMEND.RU внизу по центру (как в образце) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RECOMMEND.RU"
        android:textAlignment="center"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"/>

</LinearLayout>
